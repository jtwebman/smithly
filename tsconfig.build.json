{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts"]
}
